# Copy to .env.local and fill in all values before running.

# Neon Postgres (already set from previous deployment)
DATABASE_URL="postgres://..."

# JWT — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-random-secret"

# Admin seed (used once with: node --env-file=.env.local scripts/seed-admin.mjs)
ADMIN_NAME="Administrator"
ADMIN_EMAIL="admin@neurospine.com"
ADMIN_PASSWORD="choose-a-strong-password"

# Cloudinary (free tier — 25GB storage)
# cloud_name and api_key from your dashboard; api_secret is shown once at creation
CLOUDINARY_CLOUD_NAME="dzhickqbp"
CLOUDINARY_API_KEY="999448813757922"
CLOUDINARY_API_SECRET="your_api_secret_here"
